{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for RustyMirror",
  "platforms": [
    "linux",
    "macOS",
    "windows"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "opener:default",
    "opener:allow-open-url",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "shell:default",
    "store:default"
  ]
}